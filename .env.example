# Firebase web app config (Firebase console → Project settings → Your apps).
# Without these the app still works fully offline; sign-in and sync are hidden.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Domain that receives forwarded bank emails (bills+<token>@<this-domain>).
VITE_INBOUND_EMAIL_DOMAIN=
