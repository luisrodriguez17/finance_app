# Assistant chatbot configuration (functions/.env — deployed with the function).
# Copy to functions/.env and fill in the provider you use.

# Which LLM backend to use: gemini | groq | ollama | anthropic
# Start free with gemini or groq; switch to anthropic when the app earns money.
LLM_PROVIDER=gemini

# Messages each user may send per day.
CHAT_DAILY_LIMIT=20

# --- gemini (default, free tier at https://aistudio.google.com) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- groq (free tier at https://console.groq.com) ---
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- ollama (self-hosted; must be reachable FROM the cloud function) ---
# OLLAMA_URL=https://your-ollama-host:11434
# OLLAMA_MODEL=llama3.2

# --- anthropic (paid upgrade path) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5   # or claude-opus-4-8 for max quality

# Existing: inbound email webhook shared secret.
# INBOUND_WEBHOOK_SECRET=
